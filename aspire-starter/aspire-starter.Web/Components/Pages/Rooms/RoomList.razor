@attribute [Authorize]
@page "/rooms"
@inject RoomApiClient RoomApi
@inject PatientApiClient PatientApi
@rendermode RenderMode.InteractiveServer

<PageTitle>Room Management - HospiCare</PageTitle>

<div class="page-header">
    <h3>Room & Bed Management</h3>
</div>

@if (rooms is null)
{
    <div class="d-flex justify-content-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var room in rooms)
        {
            <div class="col-md-4">
                <div class="card room-card @(room.IsOccupied ? "border-danger" : "border-success")" style="border-width:2px;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="card-title mb-1">@room.DisplayName</h5>
                                <span class="badge @(room.IsOccupied ? "bg-danger" : "bg-success")">
                                    @(room.IsOccupied ? "Occupied" : "Available")
                                </span>
                            </div>
                            <div style="font-size:1.5rem;opacity:0.2;">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                    <polyline points="9 22 9 12 15 12 15 22"/>
                                </svg>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-muted">
                                    <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                                    <line x1="9" y1="2" x2="9" y2="22"/>
                                </svg>
                                <small class="text-muted">@room.Department?.Name</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-muted">
                                    <line x1="12" y1="1" x2="12" y2="23"/>
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                </svg>
                                <small class="text-muted">$@room.DailyRate.ToString("N2") / day</small>
                            </div>
                        </div>
                        @if (room.IsOccupied && room.CurrentPatient is not null)
                        {
                            <div class="p-2 rounded-2 mb-2" style="background: var(--rose-50);">
                                <div class="d-flex align-items-center mb-1">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1 text-danger">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                        <circle cx="12" cy="7" r="4"/>
                                    </svg>
                                    <small class="fw-medium">@room.CurrentPatient.FullName</small>
                                </div>
                                <small class="text-muted">Admitted: @room.AdmissionDate?.ToShortDateString()</small>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        @if (room.IsOccupied)
                        {
                            <button class="btn btn-sm btn-warning" @onclick="() => Discharge(room.Id)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                Discharge
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => ShowAssign(room)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                                </svg>
                                Assign Patient
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (showAssignModal && selectedRoom is not null)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Assign Patient to @selectedRoom.DisplayName</h5>
                    <button type="button" class="btn-close" @onclick="() => showAssignModal = false"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Select Patient</label>
                    <select @bind="assignPatientId" class="form-select">
                        <option value="0">Select Patient</option>
                        @foreach (var p in patients)
                        {
                            <option value="@p.Id">@p.FullName (@p.Phone)</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showAssignModal = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="AssignPatient">Assign</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RoomDto>? rooms;
    private List<PatientDto> patients = [];
    private RoomDto? selectedRoom;
    private bool showAssignModal;
    private int assignPatientId;

    protected override async Task OnInitializedAsync()
    {
        rooms = await RoomApi.GetAllAsync();
        patients = await PatientApi.GetAllAsync();
    }

    private void ShowAssign(RoomDto room)
    {
        selectedRoom = room;
        showAssignModal = true;
        assignPatientId = 0;
    }

    private async Task AssignPatient()
    {
        if (selectedRoom is not null && assignPatientId > 0)
        {
            await RoomApi.AssignAsync(selectedRoom.Id, assignPatientId);
            showAssignModal = false;
            rooms = await RoomApi.GetAllAsync();
        }
    }

    private async Task Discharge(int roomId)
    {
        await RoomApi.DischargeAsync(roomId);
        rooms = await RoomApi.GetAllAsync();
    }
}
