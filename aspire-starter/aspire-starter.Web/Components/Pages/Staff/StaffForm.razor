@attribute [Authorize]
@page "/staff/add"
@page "/staff/edit/{id:int}"
@inject StaffApiClient StaffApi
@inject DepartmentApiClient DepartmentApi
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<PageTitle>@title - HospiCare</PageTitle>

<div class="page-header">
    <h3>@title</h3>
    <div class="page-actions">
        <a href="/staff" class="btn btn-secondary">Cancel</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <EditForm Model="staffMember" OnValidSubmit="Save" class="row g-3">
            <DataAnnotationsValidator />

            <div class="col-md-6">
                <label class="form-label">First Name *</label>
                <InputText @bind-Value="staffMember.FirstName" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Last Name *</label>
                <InputText @bind-Value="staffMember.LastName" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Role</label>
                <select @bind="staffMember.Role" class="form-select">
                    <option value="">Select Role</option>
                    <option value="Nurse">Nurse</option>
                    <option value="Receptionist">Receptionist</option>
                    <option value="Admin">Admin</option>
                    <option value="Technician">Technician</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Department</label>
                <select @bind="staffMember.DepartmentId" class="form-select">
                    <option value="0">Select Department</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.Id">@dept.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Salary</label>
                <InputNumber @bind-Value="staffMember.Salary" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Phone</label>
                <InputText @bind-Value="staffMember.Phone" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <InputText @bind-Value="staffMember.Email" class="form-control" />
            </div>
            <div class="col-12 pt-3 border-top">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    Save
                </button>
                <a href="/staff" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private string title = "Add Staff";
    private StaffDto staffMember = new();
    private List<DepartmentDto> departments = [];

    [Parameter] public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        departments = await DepartmentApi.GetAllAsync();
        if (Id > 0)
        {
            title = "Edit Staff";
            var existing = await StaffApi.GetByIdAsync(Id);
            if (existing is not null) staffMember = existing;
        }
    }

    private async Task Save()
    {
        if (Id > 0)
            await StaffApi.UpdateAsync(Id, staffMember);
        else
            await StaffApi.CreateAsync(staffMember);
        Navigation.NavigateTo("/staff");
    }
}
