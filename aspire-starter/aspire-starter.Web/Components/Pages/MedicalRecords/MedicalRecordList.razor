@attribute [Authorize]
@page "/medical-records"
@page "/medical-records/patient/{patientId:int}"
@inject MedicalRecordApiClient RecordApi
@inject PatientApiClient PatientApi
@inject DoctorApiClient DoctorApi
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<PageTitle>Medical Records - HospiCare</PageTitle>

<div class="page-header">
    <h3>Medical Records</h3>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success d-flex align-items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        @message
    </div>
}

<div class="filter-bar">
    <div>
        <label class="form-label">Patient</label>
        <select @bind="selectedPatientId" class="form-select" style="width:250px;">
            <option value="0">Select Patient</option>
            @foreach (var p in patients)
            {
                <option value="@p.Id">@p.FullName</option>
            }
        </select>
    </div>
    <div>
        <button class="btn btn-primary" @onclick="LoadRecords">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            Load Records
        </button>
    </div>
</div>

@if (records is not null && selectedPatientId > 0)
{
    <button class="btn btn-success mb-3" @onclick="() => showForm = !showForm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        @(showForm ? "Hide Form" : "Add New Record")
    </button>

    @if (showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">New Medical Record</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Doctor</label>
                        <select @bind="newRecord.DoctorId" class="form-select">
                            <option value="0">Select Doctor</option>
                            @foreach (var d in doctors)
                            {
                                <option value="@d.Id">@d.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Diagnosis *</label>
                        <textarea @bind="newRecord.Diagnosis" class="form-control" rows="2" placeholder="Enter diagnosis..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Treatment</label>
                        <textarea @bind="newRecord.Treatment" class="form-control" rows="2" placeholder="Treatment plan..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Prescription</label>
                        <textarea @bind="newRecord.Prescription" class="form-control" rows="2" placeholder="Medications..."></textarea>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="SaveRecord">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/>
                                <polyline points="7 3 7 8 15 8"/>
                            </svg>
                            Save Record
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (records.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-file-medical"></i></div>
            <h5>No medical records for this patient</h5>
            <p class="text-muted">Add a new record to get started.</p>
        </div>
    }
    else
    {
        @foreach (var r in records.OrderByDescending(r => r.RecordDate))
        {
            <div class="record-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-medium">@r.RecordDate.ToShortDateString()</span>
                    <span class="text-muted">Dr. @r.Doctor?.FullName</span>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <span class="badge bg-primary me-1" style="font-size:0.7rem;">DIAGNOSIS</span>
                        <p class="mb-0 mt-1">@r.Diagnosis</p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(r.Treatment))
                    {
                        <div class="mb-2">
                            <span class="badge bg-success me-1" style="font-size:0.7rem;">TREATMENT</span>
                            <p class="mb-0 mt-1">@r.Treatment</p>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(r.Prescription))
                    {
                        <div class="mb-2">
                            <span class="badge bg-warning me-1" style="font-size:0.7rem;">PRESCRIPTION</span>
                            <p class="mb-0 mt-1">@r.Prescription</p>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(r.Notes))
                    {
                        <p class="text-muted mt-2 mb-0" style="font-size:0.85rem;">@r.Notes</p>
                    }
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public int PatientId { get; set; }

    private List<PatientDto> patients = [];
    private List<DoctorDto> doctors = [];
    private List<MedicalRecordDto>? records;
    private int selectedPatientId;
    private bool showForm;
    private string? message;
    private MedicalRecordDto newRecord = new();

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientApi.GetAllAsync();
        doctors = await DoctorApi.GetAllAsync();
        if (PatientId > 0)
        {
            selectedPatientId = PatientId;
            await LoadRecords();
        }
    }

    private async Task LoadRecords()
    {
        if (selectedPatientId > 0)
            records = await RecordApi.GetByPatientAsync(selectedPatientId);
    }

    private async Task SaveRecord()
    {
        newRecord.PatientId = selectedPatientId;
        await RecordApi.CreateAsync(newRecord);
        newRecord = new();
        showForm = false;
        message = "Record saved successfully!";
        await LoadRecords();
    }
}
