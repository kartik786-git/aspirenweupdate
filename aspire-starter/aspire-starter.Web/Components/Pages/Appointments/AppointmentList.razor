@attribute [Authorize]
@page "/appointments"
@inject AppointmentApiClient AppointmentApi
@rendermode RenderMode.InteractiveServer

<PageTitle>Appointments - HospiCare</PageTitle>

<div class="page-header">
    <h3>Appointments</h3>
    <div class="page-actions">
        <a href="/appointments/book" class="btn btn-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Book Appointment
        </a>
    </div>
</div>

<div class="filter-bar">
    <div>
        <label class="form-label">Filter by Date</label>
        <input type="date" class="form-control" style="width:auto;"
               value="@filterDate" @onchange="OnDateFilterChanged" />
    </div>
    <div>
        <label class="form-label">Status</label>
        <select class="form-select" style="width:auto;"
                value="@filterStatus" @onchange="OnStatusFilterChanged">
            <option value="">All Status</option>
            <option value="Scheduled">Scheduled</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
</div>

@if (appointments is null)
{
    <div class="d-flex justify-content-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (appointments.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-calendar-check"></i></div>
        <h5>No appointments found</h5>
        <p class="text-muted">Try adjusting your filters or book a new appointment.</p>
        <a href="/appointments/book" class="btn btn-primary mt-2">Book Appointment</a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-card">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in appointments)
                        {
                            <tr>
                                <td><a href="/patients/@a.PatientId" class="fw-medium">@a.Patient?.FullName</a></td>
                                <td>@a.Doctor?.FullName</td>
                                <td>@a.AppointmentDate.ToShortDateString()</td>
                                <td>@a.StartTime - @a.EndTime</td>
                                <td><span class="badge @GetBadge(a.Status)">@a.Status</span></td>
                                <td class="text-end">
                                    @if (a.Status == "Scheduled")
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => Complete(a.Id)">Complete</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => Cancel(a.Id)">Cancel</button>
                                    }
                                    @if (a.Status == "Completed")
                                    {
                                        <span class="text-muted" style="font-size:0.8rem;">Completed</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<AppointmentDto>? appointments;
    private string? filterDate;
    private string filterStatus = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task OnDateFilterChanged(ChangeEventArgs e)
    {
        filterDate = e.Value?.ToString();
        await LoadData();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        filterStatus = e.Value?.ToString() ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        DateTime? date = null;
        if (!string.IsNullOrWhiteSpace(filterDate))
            date = DateTime.Parse(filterDate);
        appointments = await AppointmentApi.GetAllAsync(date, string.IsNullOrWhiteSpace(filterStatus) ? null : filterStatus);
    }

    private async Task Complete(int id)
    {
        await AppointmentApi.CompleteAsync(id);
        await LoadData();
    }

    private async Task Cancel(int id)
    {
        await AppointmentApi.CancelAsync(id);
        await LoadData();
    }

    private static string GetBadge(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
}
