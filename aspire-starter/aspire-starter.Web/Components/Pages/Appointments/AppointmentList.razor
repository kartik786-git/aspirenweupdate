@attribute [Authorize]
@page "/appointments"
@inject AppointmentApiClient AppointmentApi
@rendermode RenderMode.InteractiveServer

<PageTitle>Appointments</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Appointments</h3>
    <a href="/appointments/book" class="btn btn-success">+ Book Appointment</a>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <label class="form-label">Filter by Date</label>
        <input type="date" class="form-control"
               value="@filterDate" @onchange="OnDateFilterChanged" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select class="form-select"
                value="@filterStatus" @onchange="OnStatusFilterChanged">
            <option value="">All</option>
            <option value="Scheduled">Scheduled</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
</div>

@if (appointments is null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (appointments.Count == 0)
{
    <div class="alert alert-info">No appointments found.</div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Date</th>
                <th>Time</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in appointments)
            {
                <tr>
                    <td><a href="/patients/@a.PatientId">@a.Patient?.FullName</a></td>
                    <td>@a.Doctor?.FullName</td>
                    <td>@a.AppointmentDate.ToShortDateString()</td>
                    <td>@a.StartTime - @a.EndTime</td>
                    <td><span class="badge @GetBadge(a.Status)">@a.Status</span></td>
                    <td>
                        @if (a.Status == "Scheduled")
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => Complete(a.Id)">Complete</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Cancel(a.Id)">Cancel</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AppointmentDto>? appointments;
    private string? filterDate;
    private string filterStatus = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task OnDateFilterChanged(ChangeEventArgs e)
    {
        filterDate = e.Value?.ToString();
        await LoadData();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        filterStatus = e.Value?.ToString() ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        DateTime? date = null;
        if (!string.IsNullOrWhiteSpace(filterDate))
            date = DateTime.Parse(filterDate);
        appointments = await AppointmentApi.GetAllAsync(date, string.IsNullOrWhiteSpace(filterStatus) ? null : filterStatus);
    }

    private async Task Complete(int id)
    {
        await AppointmentApi.CompleteAsync(id);
        await LoadData();
    }

    private async Task Cancel(int id)
    {
        await AppointmentApi.CancelAsync(id);
        await LoadData();
    }

    private static string GetBadge(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
}
