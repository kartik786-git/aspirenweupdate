@attribute [Authorize]
@page "/doctors"
@inject DoctorApiClient DoctorApi
@rendermode RenderMode.InteractiveServer

<PageTitle>Doctors</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Doctor Directory</h3>
    <a href="/doctors/add" class="btn btn-success">+ Add Doctor</a>
</div>

@if (doctors is null)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (doctors.Count == 0)
{
    <div class="alert alert-info">No doctors found.</div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Specialization</th>
                <th>Department</th>
                <th>Qualification</th>
                <th>Experience</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in doctors)
            {
                <tr>
                    <td>@d.FullName</td>
                    <td>@d.Specialization</td>
                    <td>@d.Department?.Name</td>
                    <td>@d.Qualification</td>
                    <td>@d.ExperienceYears yrs</td>
                    <td>@d.Phone</td>
                    <td>
                        <span class="badge @(d.IsActive ? "bg-success" : "bg-danger")">
                            @(d.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <a href="/doctors/edit/@d.Id" class="btn btn-sm btn-warning">Edit</a>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(d.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DoctorDto>? doctors;

    protected override async Task OnInitializedAsync()
    {
        doctors = await DoctorApi.GetAllAsync();
    }

    private async Task Delete(int id)
    {
        await DoctorApi.DeleteAsync(id);
        doctors = await DoctorApi.GetAllAsync();
    }
}
