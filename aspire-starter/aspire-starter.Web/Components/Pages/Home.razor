@attribute [Authorize]
@page "/"
@inject DashboardApiClient DashboardApi
@rendermode RenderMode.InteractiveServer

<PageTitle>Dashboard - HospiCare</PageTitle>

<div class="page-header">
    <div>
        <h3>Hospital Dashboard</h3>
        <p class="text-muted mb-0" style="font-size:0.875rem;">Welcome back! Here is your hospital overview for today.</p>
    </div>
    <div class="page-actions">
        <a href="/appointments/book" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Book Appointment
        </a>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient-primary text-white">
                <div class="stat-label">Total Patients</div>
                <div class="stat-value">@summary.TotalPatients</div>
                <i class="bi bi-people-fill stat-icon"></i>
                <div style="font-size:0.75rem;opacity:0.7;margin-top:0.5rem;">
                    <i class="bi bi-arrow-up"></i> Active records
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient-success text-white">
                <div class="stat-label">Active Doctors</div>
                <div class="stat-value">@summary.ActiveDoctors</div>
                <i class="bi bi-person-badge-fill stat-icon"></i>
                <div style="font-size:0.75rem;opacity:0.7;margin-top:0.5rem;">
                    <i class="bi bi-person-check"></i> On staff
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient-warning text-white">
                <div class="stat-label">Today's Appointments</div>
                <div class="stat-value">@summary.TodayAppointments</div>
                <i class="bi bi-calendar-check-fill stat-icon"></i>
                <div style="font-size:0.75rem;opacity:0.7;margin-top:0.5rem;">
                    <i class="bi bi-clock"></i> Scheduled today
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient-info text-white">
                <div class="stat-label">Monthly Revenue</div>
                <div class="stat-value">$@summary.MonthlyRevenue.ToString("N0")</div>
                <i class="bi bi-currency-dollar stat-icon"></i>
                <div style="font-size:0.75rem;opacity:0.7;margin-top:0.5rem;">
                    <i class="bi bi-graph-up"></i> This month
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="card-title mb-0">Bed Occupancy</h6>
                        <span class="badge bg-primary">@summary.OccupancyRate.ToString("F0")%</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted" style="font-size:0.8rem;">@summary.OccupiedRooms occupied / @summary.TotalRooms total</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: @summary.OccupancyRate%" aria-valuenow="@summary.OccupancyRate" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100" style="border-left: 4px solid #f43f5e;">
                <div class="card-body">
                    <h6 class="card-title">Pending Bills</h6>
                    <h3 class="text-danger">@summary.PendingBills</h3>
                    <a href="/billing" class="btn btn-outline-danger btn-sm">View Bills</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 quick-actions">
                <div class="card-body">
                    <h6 class="card-title mb-3">Quick Actions</h6>
                    <div class="d-grid gap-2">
                        <a href="/patients/add" class="btn btn-primary">Register New Patient</a>
                        <a href="/appointments/book" class="btn btn-success">Book Appointment</a>
                        <a href="/patients" class="btn btn-info text-white">View All Patients</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>System Overview</span>
                    <span class="badge bg-primary">Live</span>
                </div>
                <div class="card-body">
                    <div class="row g-4 text-center">
                        <div class="col-3">
                            <p class="text-muted small text-uppercase mb-1">Total Rooms</p>
                            <h3>@summary.TotalRooms</h3>
                        </div>
                        <div class="col-3">
                            <p class="text-muted small text-uppercase mb-1">Occupied</p>
                            <h3 class="text-danger">@summary.OccupiedRooms</h3>
                        </div>
                        <div class="col-3">
                            <p class="text-muted small text-uppercase mb-1">Available</p>
                            <h3 class="text-success">@(summary.TotalRooms - summary.OccupiedRooms)</h3>
                        </div>
                        <div class="col-3">
                            <p class="text-muted small text-uppercase mb-1">Active Doctors</p>
                            <h3>@summary.ActiveDoctors</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardSummaryDto? summary;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        summary = await DashboardApi.GetSummaryAsync();
        _loading = false;
    }
}
