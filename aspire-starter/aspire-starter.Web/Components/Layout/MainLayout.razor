@using Microsoft.AspNetCore.Authentication
@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@inject TokenService TokenService

<div class="layout-wrapper">
    <aside class="sidebar @(_sidebarOpen ? "open" : "")">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand">
                <div class="brand-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                    </svg>
                </div>
                <div class="brand-text">
                    <span class="brand-name">HospiCare</span>
                    <span class="brand-version">Hospital HMS</span>
                </div>
            </a>
        </div>
        <NavMenu />
    </aside>

    <div class="main-area">
        <header class="top-header">
            <div class="header-left">
                <button class="sidebar-toggle d-xl-none" @onclick="ToggleSidebar" aria-label="Toggle navigation">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
                <div class="header-search d-none d-md-flex">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" placeholder="Search patients, doctors..." disabled />
                </div>
            </div>
            <div class="header-right">
                <div class="header-notifications">
                    <button class="icon-btn" title="Notifications">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                </div>
                <LoginDisplay />
            </div>
        </header>

        <main class="content-area">
            <article class="content-inner">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    <span>An unhandled error has occurred.</span>
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@code {
    private bool _sidebarOpen = false;

    protected override async Task OnInitializedAsync()
    {
        // Capture access token during initial HTTP request (pre-rendering)
        // so it's available for API calls during SignalR circuit operations
        if (string.IsNullOrEmpty(TokenService.AccessToken))
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext is not null)
            {
                var token = await httpContext.GetTokenAsync("access_token");
                if (!string.IsNullOrEmpty(token))
                {
                    TokenService.AccessToken = token;
                }
            }
        }
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }
}
