@using Microsoft.AspNetCore.Authentication
@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@inject TokenService TokenService
@inject PersistentComponentState PersistentComponentState
@inject AuthEventService AuthEventService
@inject NavigationManager Navigation

<div class="layout-wrapper">
    <aside class="sidebar @(_sidebarOpen ? "open" : "")">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand">
                <div class="brand-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                    </svg>
                </div>
                <div class="brand-text">
                    <span class="brand-name">HospiCare</span>
                    <span class="brand-version">Hospital HMS</span>
                </div>
            </a>
        </div>
        <NavMenu />
    </aside>

    <div class="main-area">
        <header class="top-header">
            <div class="header-left">
                <button class="sidebar-toggle d-xl-none" @onclick="ToggleSidebar" aria-label="Toggle navigation">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
                <div class="header-search d-none d-md-flex">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" placeholder="Search patients, doctors..." disabled />
                </div>
            </div>
            <div class="header-right">
                <div class="header-notifications">
                    <button class="icon-btn" title="Notifications">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <span class="notification-dot"></span>
                    </button>
                </div>
                <LoginDisplay />
            </div>
        </header>

        <main class="content-area">
            <article class="content-inner">
                <ErrorBoundary>
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="d-flex justify-content-center align-items-center" style="min-height:300px;">
                            <div class="text-center" style="max-width:360px;">
                                <div class="mb-3" style="color:var(--gray-300);">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="12" y1="8" x2="12" y2="12"/>
                                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                                    </svg>
                                </div>
                                <h5 style="color:var(--gray-700);font-weight:600;margin-bottom:0.5rem;">Unable to Load Page</h5>
                                <p style="color:var(--gray-500);font-size:0.875rem;margin-bottom:0.25rem;line-height:1.5;">
                                    The page could not be loaded due to a temporary issue.
                                </p>
                                <p style="color:var(--gray-400);font-size:0.8rem;margin-bottom:1.25rem;">
                                    This usually happens when your session has expired or the server is unreachable.
                                    Try refreshing the page or signing in again.
                                </p>
                                <div class="d-flex gap-2 justify-content-center">
                                    <a href="/auth/reauth?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" class="btn btn-primary btn-sm">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                                            <polyline points="10 17 15 12 10 7"/>
                                            <line x1="15" y1="12" x2="3" y2="12"/>
                                        </svg>
                                        Sign In
                                    </a>
                                    <button class="btn btn-outline-secondary btn-sm" onclick="location.reload()">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                                            <polyline points="23 4 23 10 17 10"/>
                                            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                                        </svg>
                                        Refresh Page
                                    </button>
                                </div>
                            </div>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </article>
        </main>
    </div>
</div>

@if (_reauthState != ReauthState.Idle)
{
    <div class="reauth-overlay">
        <div class="reauth-card">
            <div class="mb-4">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <h4 class="mb-2">Session Expired</h4>
            <p class="reauth-message">
                @if (_reauthState == ReauthState.Failed)
                {
                    <span>Your session has expired. Please sign in again to continue using HospiCare.</span>
                }
                else
                {
                    <span>Redirecting to login...</span>
                }
            </p>
            <div class="reauth-actions">
                <a href="/auth/reauth?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    Sign In Again
                </a>
                <a href="/auth/logout" class="btn btn-outline-secondary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Sign Out
                </a>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui">
    <span>An unhandled error has occurred.</span>
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@code {
    private bool _sidebarOpen = false;
    private ReauthState _reauthState = ReauthState.Idle;

    private const string AccessTokenKey = "AccessToken";
    private const string RefreshTokenKey = "RefreshToken";

    protected override async Task OnInitializedAsync()
    {
        // 1. During interactive rendering (SignalR circuit), restore tokens that were
        //    persisted by App.razor during prerendering
        var restored = PersistentComponentState.TryTakeFromJson<string>(AccessTokenKey, out var accessToken);
        PersistentComponentState.TryTakeFromJson<string>(RefreshTokenKey, out var refreshToken);

        if (restored && !string.IsNullOrEmpty(accessToken))
        {
            TokenService.AccessToken = accessToken;
            if (!string.IsNullOrEmpty(refreshToken))
                TokenService.RefreshToken = refreshToken;
            return;
        }

        // 2. During prerendering (HTTP request), capture tokens from the cookie
        if (string.IsNullOrEmpty(TokenService.AccessToken))
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext is not null)
            {
                var token = await httpContext.GetTokenAsync("access_token");
                if (!string.IsNullOrEmpty(token))
                {
                    TokenService.AccessToken = token;
                }

                var rToken = await httpContext.GetTokenAsync("refresh_token");
                if (!string.IsNullOrEmpty(rToken))
                {
                    TokenService.RefreshToken = rToken;
                }
            }
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        // Check the flag after each render — if the TokenHandler detected a 401 during
        // prerendering or the SignalR circuit, show the overlay on the next render cycle.
        if (AuthEventService.ReauthenticationRequired && _reauthState == ReauthState.Idle)
        {
            _reauthState = ReauthState.Failed;
            StateHasChanged();
        }
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private enum ReauthState { Idle, Failed, Redirecting }
}
